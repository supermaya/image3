# ─── Firebase Functions .gcloudignore ───────────────────────────────────────
# Cloud Build가 서버에서 npm install을 실행하므로 node_modules 업로드 불필요
# 목표: 배포 패키지 102MB 이하 유지

# ── node_modules: 가장 큰 용량 차지 (반드시 제외) ────────────────────────────
node_modules
node_modules/
**/node_modules
**/node_modules/**

# ── 개발 전용 파일 ────────────────────────────────────────────────────────────
.git
.git/**
.gitignore

# ── 로그 파일 ─────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── 테스트 파일 ───────────────────────────────────────────────────────────────
test/
tests/
*.test.js
*.spec.js
__tests__/

# ── IDE / 에디터 설정 ─────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo

# ── OS 임시 파일 ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
tmp/
temp/
